{
  "manifest_version": 3,
  "name": "CSGOEmpire Roll Tracker",
  "version": "1.0.0",
  "description": "Intercept roll results from CSGOEmpire for analysis",
  "permissions": [
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "*://*.csgoempire.com/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.csgoempire.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://*.csgoempire.com/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CSGOEmpire Tracker"
  }
}